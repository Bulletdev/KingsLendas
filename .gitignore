# Bundler
/.bundle

# Environment files
/.env
/.env.*
!/.env.example

# Master key / credentials
/config/master.key
/config/credentials/*.key

# Logs & tmp
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/.keep

# Storage / SQLite
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep
*.sqlite3
*.sqlite3-journal
*.sqlite3-shm
*.sqlite3-wal

# Assets
/node_modules/
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets

# Security tests
/security_tests/reports
/security_tests/scripts/security_tests/reports
/security_tests/security_tests/reports

# OS / Editor
.DS_Store
.idea/
.vscode/
*.swp

# Devdocs: keep only the parsed JSON, exclude large saved HTML files
/devdocs/*.html
/championstatus_files/
/playerstatus_files/

# Local dev only
/KINGS_LENDAS_PROMPT.md
/load_tests/
/security_tests/
# Kamal secrets — DO NOT COMMIT sensitive values
