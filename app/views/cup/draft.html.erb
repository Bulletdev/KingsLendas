<div class="max-w-7xl mx-auto px-4 py-10">
  <div style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:24px">
    <div>
      <div class="retro-section-label">// Kings Lendas Cup 2026</div>
      <h1 class="retro-title-lg">Picks &amp; Bans</h1>
    </div>
    <div style="display:flex;gap:4px;flex-wrap:wrap">
      <% [["Picks","picks"],["Bans","bans"],["Win%","winpct"]].each do |label, key| %>
        <% active = params[:sort].blank? ? key == "picks" : params[:sort] == key %>
        <%= link_to label, cup_draft_path(sort: key),
              style: "font-size:16px;letter-spacing:0.1em;padding:6px 12px;font-family:Verdana,sans-serif;text-transform:uppercase;text-decoration:none;border:1px solid #{active ? 'var(--retro-gold)' : 'rgba(255,255,255,0.15)'};background:#{active ? 'rgba(200,155,60,0.15)' : 'transparent'};color:#{active ? 'var(--retro-gold)' : 'rgba(255,255,255,0.45)'}" %>
      <% end %>
    </div>
  </div>

  <!-- Team filter -->
  <div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:24px" data-controller="draft-filter">
    <button data-action="click->draft-filter#filter" data-team=""
            style="font-size:16px;letter-spacing:0.1em;padding:6px 12px;font-family:Verdana,sans-serif;text-transform:uppercase;border:1px solid var(--retro-gold);background:rgba(200,155,60,0.15);color:var(--retro-gold);cursor:pointer">
      Todos os Times
    </button>
    <% @teams.each do |team| %>
      <button data-action="click->draft-filter#filter" data-team="<%= team %>"
              style="font-size:16px;letter-spacing:0.1em;padding:6px 12px;font-family:Verdana,sans-serif;text-transform:uppercase;border:1px solid rgba(255,255,255,0.15);background:transparent;color:rgba(255,255,255,0.45);cursor:pointer;display:flex;align-items:center;gap:6px"
              onmouseover="this.style.borderColor='var(--retro-gold-dim)';this.style.color='var(--retro-gold)'"
              onmouseout="this.style.borderColor='rgba(255,255,255,0.15)';this.style.color='rgba(255,255,255,0.45)'">
        <%= team_logo(team, size: 16) %>
        <%= team_abbr(team) %>
      </button>
    <% end %>
  </div>

  <% if @champion_stats.any? %>
    <!-- Top picks visual -->
    <div style="margin-bottom:24px">
      <div style="margin-bottom:12px">
        <div class="retro-section-label">// MAIS PICADOS</div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
        <% @champion_stats.first(10).each_with_index do |champ, idx| %>
          <% picks = champ["Picks"].to_i; bans = champ["Bans"].to_i; wins = champ["Wins"].to_i %>
          <div style="border:1px solid var(--retro-gold-dim);background:var(--retro-card);padding:12px 8px;text-align:center;position:relative">
            <div class="retro-corners"></div>
            <div style="position:absolute;top:4px;left:6px;font-size:17px;font-weight:bold;color:var(--retro-gold);font-family:Verdana,sans-serif">#<%= idx + 1 %></div>
            <%= champion_icon(champ["Champion"], size: 52, css_class: "mx-auto") %>
            <p style="font-size:17px;font-weight:bold;color:rgba(255,255,255,0.85);font-family:Verdana,sans-serif;margin-top:6px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= champ["Champion"] %></p>
            <div style="display:flex;justify-content:center;gap:8px;margin-top:4px">
              <span style="font-size:16px;color:var(--retro-teal);font-family:Verdana,sans-serif"><%= picks %>P</span>
              <span style="color:rgba(255,255,255,0.2)">◆</span>
              <span style="font-size:16px;color:var(--retro-gold);font-family:Verdana,sans-serif"><%= bans %>B</span>
            </div>
            <p style="font-size:16px;color:rgba(255,255,255,0.35);font-family:Verdana,sans-serif;margin-top:3px">
              <%= picks > 0 ? "#{(wins.to_f / picks * 100).round}% win" : "—" %>
            </p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Full table -->
    <%= retro_panel(title: "Tabela Completa", category: "// DRAFT", footer: "Kings Lendas Cup 2026") do %>
      <div class="overflow-x-auto">
        <table style="width:100%;border-collapse:collapse">
          <thead>
            <tr style="border-bottom:1px solid var(--retro-gold-dim)">
              <th class="retro-table-head" style="text-align:left">Campeão</th>
              <th class="retro-table-head" style="text-align:center">Picks</th>
              <th class="retro-table-head" style="text-align:center">Bans</th>
              <th class="retro-table-head" style="text-align:center">Vitórias</th>
              <th class="retro-table-head" style="text-align:center">Derrotas</th>
              <th class="retro-table-head" style="text-align:center">Win%</th>
              <th class="retro-table-head hidden md:table-cell" style="text-align:center">Presença%</th>
            </tr>
          </thead>
          <tbody>
            <% @champion_stats.each do |champ| %>
              <% picks = champ["Picks"].to_i; bans = champ["Bans"].to_i; wins = champ["Wins"].to_i; losses = picks - wins %>
              <% total_games = @champion_stats.map { |c| c["Games"].to_i }.max.to_f %>
              <% presence = total_games > 0 ? ((picks + bans).to_f / (total_games + 1) * 100).clamp(0, 100).round : 0 %>
              <% win_pct = picks > 0 ? (wins.to_f / picks * 100).round : 0 %>
              <tr class="retro-table-row" style="border-bottom:1px solid rgba(200,155,60,0.08)" data-champion-row="<%= champ['Champion'] %>" data-teams="<%= @champ_teams[champ['Champion']] || '' %>">
                <td style="padding:10px 12px 10px 0">
                  <div style="display:flex;align-items:center;gap:10px">
                    <%= champion_icon(champ["Champion"], size: 36) %>
                    <span style="font-size:16px;font-weight:bold;color:rgba(255,255,255,0.85);font-family:Verdana,sans-serif"><%= champ["Champion"] %></span>
                  </div>
                </td>
                <td style="padding:10px 8px;text-align:center">
                  <span style="font-size:17px;font-weight:bold;color:var(--retro-teal);font-family:Verdana,sans-serif"><%= picks %></span>
                </td>
                <td style="padding:10px 8px;text-align:center">
                  <span style="font-size:17px;font-weight:bold;color:var(--retro-gold);font-family:Verdana,sans-serif"><%= bans %></span>
                </td>
                <td style="padding:10px 8px;text-align:center;font-size:16px;font-weight:bold;color:var(--color-kl-win);font-family:Verdana,sans-serif"><%= wins %></td>
                <td style="padding:10px 8px;text-align:center;font-size:16px;font-weight:bold;color:var(--color-kl-loss);font-family:Verdana,sans-serif"><%= picks > 0 ? losses : "—" %></td>
                <td style="padding:10px 8px;text-align:center">
                  <span style="font-size:16px;font-weight:bold;font-family:Verdana,sans-serif;color:<%= win_pct >= 60 ? 'var(--color-kl-win)' : (win_pct >= 40 ? 'rgba(255,255,255,0.7)' : 'var(--color-kl-loss)') %>">
                    <%= picks > 0 ? "#{win_pct}%" : "—" %>
                  </span>
                </td>
                <td class="hidden md:table-cell" style="padding:10px 8px;text-align:center;font-size:16px;color:rgba(255,255,255,0.4);font-family:Verdana,sans-serif">
                  <%= presence %>%
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  <% else %>
    <div style="border:1px solid var(--retro-gold-dim);padding:64px 20px;text-align:center;position:relative">
      <div class="retro-corners"></div>
      <div style="font-size:17px;color:rgba(255,255,255,0.3);font-family:Verdana,sans-serif">Dados de picks &amp; bans não disponíveis ainda</div>
    </div>
  <% end %>
</div>
