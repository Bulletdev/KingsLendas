<nav style="position:sticky;top:0;z-index:50;background:rgba(10,14,26,0.95);backdrop-filter:blur(8px);border-bottom:1px solid var(--retro-gold-dim);font-family:var(--retro-font)">
  <!-- gold top strip -->
  <div style="height:2px;background:linear-gradient(to right,var(--retro-gold),transparent)"></div>

  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between" style="height:56px">

      <!-- Logo -->
      <%= link_to root_path, style: "display:flex;align-items:center;gap:10px;text-decoration:none" do %>
        <%= image_tag "/Kings_Lendas_Cup.webp", alt: "Kings Lendas Cup", width: 32, height: 32,
              style: "object-fit:contain;filter:drop-shadow(0 0 8px rgba(200,155,60,0.5))",
              onerror: "this.onerror=null;this.outerHTML='<div style=\"width:32px;height:32px;background:var(--retro-gold);display:flex;align-items:center;justify-content:center;\"><span style=\"color:#0A0E1A;font-weight:900;font-size:12px;font-family:Verdana\">KL</span></div>'" %>
        <div>
          <div style="font-size:14px;font-weight:bold;color:var(--retro-gold);letter-spacing:0.06em;line-height:1.2;text-shadow:0 0 12px rgba(200,155,60,0.5)">KINGS LENDAS</div>
          <div style="font-size:9px;color:var(--retro-gold-dim);letter-spacing:0.2em">CUP 2026 ◆ BY BAIANO</div>
        </div>
      <% end %>

      <!-- Nav links desktop -->
      <div class="hidden md:flex items-center" style="gap:2px">
        <% nav_links = [
          ["Copa",         cup_path],
          ["Classificação",cup_standings_path],
          ["Partidas",     cup_matches_path],
          ["Resultados",   cup_results_path],
          ["Picks & Bans", cup_draft_path],
          ["Campeões",     cup_champions_path],
          ["Jogadores",    cup_players_path],
          ["Times",        teams_path],
          ["Temporadas",   seasons_path],
        ] %>
        <% nav_links.each do |label, path| %>
          <% active = current_page?(path) %>
          <%= link_to label, path,
                style: "font-size:11px;letter-spacing:0.1em;padding:6px 10px;text-transform:uppercase;font-family:Verdana,sans-serif;text-decoration:none;transition:all 0.15s;#{active ? 'color:var(--retro-gold);border-bottom:2px solid var(--retro-gold);' : 'color:rgba(255,255,255,0.5);border-bottom:2px solid transparent;'}",
                onmouseover: active ? "" : "this.style.color='rgba(255,255,255,0.85)';this.style.borderBottomColor='var(--retro-gold-dim)'",
                onmouseout:  active ? "" : "this.style.color='rgba(255,255,255,0.5)';this.style.borderBottomColor='transparent'" %>
        <% end %>
      </div>

      <!-- Live badge + mobile hamburger -->
      <div class="flex items-center gap-3">
        <a href="https://kick.com/BaianoTV" target="_blank" rel="noopener"
           class="hidden sm:flex items-center gap-2"
           style="font-size:10px;font-weight:bold;letter-spacing:0.12em;color:#fff;background:#e53e3e;padding:5px 12px;border:1px solid #fc8181;font-family:Verdana,sans-serif;text-decoration:none">
          <span style="width:5px;height:5px;border-radius:50%;background:#fff;animation:live-pulse 2s ease-in-out infinite;display:inline-block"></span>
          AO VIVO
        </a>
        <button data-controller="mobile-nav" data-action="click->mobile-nav#toggle"
                style="background:none;border:none;color:rgba(255,255,255,0.6);cursor:pointer;padding:4px" class="md:hidden">
          <i class="ri-menu-line" style="font-size:22px"></i>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <div data-mobile-nav-target="menu" class="md:hidden hidden" style="border-top:1px solid var(--retro-gold-dim);padding:8px 0 12px">
      <div style="display:flex;flex-direction:column;gap:1px">
        <% nav_links.each do |label, path| %>
          <%= link_to label, path,
                style: "font-size:11px;letter-spacing:0.12em;padding:8px 6px;text-transform:uppercase;font-family:Verdana,sans-serif;color:rgba(255,255,255,0.5);text-decoration:none;display:block",
                onmouseover: "this.style.color='var(--retro-gold)'",
                onmouseout:  "this.style.color='rgba(255,255,255,0.5)'" %>
        <% end %>
        <a href="https://kick.com/BaianoTV" target="_blank" rel="noopener"
           style="font-size:11px;letter-spacing:0.12em;padding:8px 6px;color:#fc8181;font-family:Verdana,sans-serif;text-decoration:none;display:flex;align-items:center;gap:6px">
          <span style="width:5px;height:5px;border-radius:50%;background:#fc8181;display:inline-block"></span>
          ASSISTIR AO VIVO
        </a>
      </div>
    </div>
  </div>
</nav>
