<div class="max-w-4xl mx-auto px-4 py-10">
  <div style="margin-bottom:24px">
    <div class="retro-section-label">// IDL Kings Lendas</div>
    <h1 class="retro-title-lg">Temporadas</h1>
  </div>

  <div style="display:flex;flex-direction:column;gap:10px">
    <% @seasons.each do |season| %>
      <% next if season[:slug] == "copa" %>
      <%
        roman = { 1 => "I", 2 => "II", 3 => "III", 4 => "IV", 5 => "V" }
        season_num = season[:slug].split("-").last.to_i
        roman_num  = roman[season_num] || season[:slug].upcase
      %>
      <%= link_to season_path(season[:slug]), style: "text-decoration:none;display:block" do %>
        <div style="border:1px solid var(--retro-gold-dim);background:var(--retro-card);padding:16px 20px;position:relative;display:flex;align-items:center;gap:16px;transition:border-color 0.15s,background 0.15s"
             onmouseover="this.style.borderColor='var(--retro-gold)';this.style.background='rgba(200,155,60,0.05)'"
             onmouseout="this.style.borderColor='var(--retro-gold-dim)';this.style.background='var(--retro-card)'">
          <div class="retro-corners"></div>
          <!-- Season logo + roman numeral badge -->
          <div style="width:56px;height:56px;flex-shrink:0;position:relative">
            <%= image_tag "/Kings_Lendas_logo.webp", alt: season[:label], width: 56, height: 56,
                  style: "width:56px;height:56px;object-fit:contain" %>
            <div style="position:absolute;bottom:-4px;right:-6px;background:var(--retro-blue-dark);border:1px solid var(--retro-gold);padding:1px 5px">
              <span style="font-size:10px;font-weight:bold;color:var(--retro-gold);font-family:var(--retro-font)"><%= roman_num %></span>
            </div>
          </div>
          <div style="flex:1">
            <p style="font-size:9px;color:var(--retro-teal);letter-spacing:0.18em;font-family:var(--retro-font);text-transform:uppercase;margin-bottom:3px">IDL Kings Lendas</p>
            <h2 style="font-size:15px;font-weight:bold;color:var(--retro-gold);font-family:var(--retro-font);letter-spacing:0.04em"><%= season[:label] %></h2>
            <p style="font-size:10px;color:rgba(255,255,255,0.3);font-family:var(--retro-font);margin-top:2px"><%= season[:name] %></p>
            <% if season[:champion] %>
              <p style="font-size:10px;color:rgba(255,255,255,0.45);font-family:var(--retro-font);margin-top:3px">◆ Campeão: <span style="color:rgba(200,155,60,0.85)"><%= season[:champion] %></span></p>
            <% end %>
          </div>
          <span style="color:var(--retro-gold-dim);font-family:var(--retro-font);font-size:16px">→</span>
        </div>
      <% end %>
    <% end %>

    <!-- Copa -->
    <%= link_to cup_path, style: "text-decoration:none;display:block" do %>
      <div style="border:1px solid var(--retro-gold);background:var(--retro-card);padding:16px 20px;position:relative;display:flex;align-items:center;gap:16px;transition:box-shadow 0.15s"
           onmouseover="this.style.boxShadow='0 0 24px rgba(200,155,60,0.2)'"
           onmouseout="this.style.boxShadow='none'">
        <div class="retro-corners"></div>
        <!-- Cup logo -->
        <div style="width:56px;height:56px;flex-shrink:0;display:flex;align-items:center;justify-content:center">
          <%= image_tag "/Kings_Lendas_Cup.webp", alt: "Kings Lendas Cup", width: 56, height: 56,
                style: "width:56px;height:56px;object-fit:contain" %>
        </div>
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:3px">
            <p style="font-size:9px;color:var(--retro-teal);letter-spacing:0.18em;font-family:var(--retro-font);text-transform:uppercase">IDL Kings Lendas</p>
            <span class="retro-status" style="color:var(--retro-teal);border-color:var(--retro-teal);font-size:8px">EM ANDAMENTO</span>
          </div>
          <h2 style="font-size:15px;font-weight:bold;color:var(--retro-gold);font-family:var(--retro-font);letter-spacing:0.04em">Kings Lendas Cup 2026</h2>
          <p style="font-size:10px;color:rgba(255,255,255,0.3);font-family:var(--retro-font);margin-top:2px">Off-season • 6 times • 06–15/Mar/2026</p>
          <p style="font-size:10px;color:rgba(200,155,60,0.7);font-family:var(--retro-font);margin-top:2px">◆ Premiação: R$ 50.000</p>
        </div>
        <span style="color:var(--retro-gold);font-family:var(--retro-font);font-size:16px">→</span>
      </div>
    <% end %>
  </div>
</div>
