<div class="max-w-7xl mx-auto px-4 py-10">
  <div style="margin-bottom:24px">
    <div class="retro-section-label">// Kings Lendas Cup 2026</div>
    <h1 class="retro-title-lg">Times</h1>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% TEAMS_DATA.select { |_, v| v.key?(:captain) }.each do |name, data| %>
      <% standing = @standings&.find { |s| s["Team"] == name } %>
      <% wins = standing&.dig("Wins").to_i || 0; losses = standing&.dig("Losses").to_i || 0 %>
      <div style="border:1px solid var(--retro-gold-dim);background:var(--retro-card);position:relative;overflow:hidden;transition:border-color 0.15s"
           onmouseover="this.style.borderColor='var(--retro-gold)'"
           onmouseout="this.style.borderColor='var(--retro-gold-dim)'">
        <div class="retro-corners"></div>

        <!-- Panel header -->
        <div style="height:2px;background:linear-gradient(to right,<%= data[:color] %>,transparent)"></div>
        <div style="padding:6px 12px;border-bottom:1px solid var(--retro-gold-dim);display:flex;align-items:center;justify-content:space-between;background:rgba(200,155,60,0.04)">
          <span style="font-size:17px;letter-spacing:0.12em;color:var(--retro-gold-dim);font-family:Verdana,sans-serif;text-transform:uppercase">// TIME</span>
          <span class="retro-status" style="font-size:17px;color:rgba(255,255,255,0.3);border-color:rgba(255,255,255,0.1)"><%= data[:parody_of] %></span>
        </div>

        <%= link_to team_path(data[:slug]), style: "display:block;padding:16px;text-decoration:none" do %>
          <!-- Team header -->
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px">
            <%= team_logo(name, size: 56) %>
            <div>
              <span style="font-size:24px;font-weight:bold;color:rgba(255,255,255,0.9);font-family:Verdana,sans-serif;display:block"><%= data[:abbr] %></span>
              <span style="font-size:17px;color:rgba(255,255,255,0.45);font-family:Verdana,sans-serif;display:block;margin-top:1px"><%= name %></span>
              <span style="font-size:16px;font-family:Verdana,sans-serif;margin-top:3px;display:block">
                Cap: <span style="color:var(--retro-gold)"><%= data[:captain] %></span>
              </span>
            </div>
          </div>

          <!-- Record -->
          <% if wins + losses > 0 %>
            <div style="display:flex;gap:6px;margin-bottom:12px">
              <div style="flex:1;text-align:center;padding:8px 4px;border:1px solid rgba(0,211,100,0.2);background:rgba(0,211,100,0.06)">
                <div style="font-size:24px;font-weight:bold;color:var(--color-kl-win);font-family:Verdana,sans-serif"><%= wins %></div>
                <div style="font-size:17px;color:rgba(255,255,255,0.35);font-family:Verdana,sans-serif;letter-spacing:0.1em">VITÓRIAS</div>
              </div>
              <div style="flex:1;text-align:center;padding:8px 4px;border:1px solid rgba(255,68,68,0.2);background:rgba(255,68,68,0.06)">
                <div style="font-size:24px;font-weight:bold;color:var(--color-kl-loss);font-family:Verdana,sans-serif"><%= losses %></div>
                <div style="font-size:17px;color:rgba(255,255,255,0.35);font-family:Verdana,sans-serif;letter-spacing:0.1em">DERROTAS</div>
              </div>
              <div style="flex:1;text-align:center;padding:8px 4px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.03)">
                <div style="font-size:24px;font-weight:bold;color:rgba(255,255,255,0.8);font-family:Verdana,sans-serif"><%= (wins.to_f / (wins + losses) * 100).round %>%</div>
                <div style="font-size:17px;color:rgba(255,255,255,0.35);font-family:Verdana,sans-serif;letter-spacing:0.1em">WIN%</div>
              </div>
            </div>
          <% end %>

          <!-- Roster preview -->
          <div style="border-top:1px solid rgba(200,155,60,0.12);padding-top:10px">
            <% data[:roster]&.reject { |m| m[:role] == "coach" }&.first(5)&.each do |member| %>
              <div style="display:flex;align-items:center;gap:8px;padding:3px 0">
                <span style="width:18px;flex-shrink:0;display:flex;align-items:center;justify-content:center"><%= lane_icon(member[:role], size: 16) %></span>
                <div style="width:4px;height:4px;border-radius:50%;background:<%= data[:color] %>;flex-shrink:0"></div>
                <span style="font-size:15px;color:rgba(255,255,255,0.7);font-family:Verdana,sans-serif;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= member[:player] %></span>
                <% if member[:captain] %><span style="color:var(--retro-gold);font-size:15px;flex-shrink:0">★</span><% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- Panel footer -->
        <div style="height:18px;background:linear-gradient(to right,var(--retro-blue),var(--retro-bg));border-top:1px solid var(--retro-gold-dim);display:flex;align-items:center;justify-content:space-between;padding:0 10px">
          <span style="font-size:17px;letter-spacing:0.1em;color:rgba(200,155,60,0.5);font-family:Verdana,sans-serif">KINGS LENDAS CUP 2026</span>
          <span style="font-size:17px;color:var(--retro-teal);font-family:Verdana,sans-serif;letter-spacing:0.08em">VER PERFIL →</span>
        </div>
      </div>
    <% end %>
  </div>
</div>
