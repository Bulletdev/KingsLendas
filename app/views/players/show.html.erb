<div class="max-w-4xl mx-auto px-4 py-10">
  <%= link_to "← Todos os jogadores", cup_players_path, style: "font-size:17px;color:rgba(255,255,255,0.35);font-family:Verdana,sans-serif;letter-spacing:0.1em;text-decoration:none;display:inline-block;margin-bottom:20px;text-transform:uppercase" %>

  <!-- Player header -->
  <div style="border:1px solid var(--retro-gold);background:var(--retro-card);position:relative;overflow:hidden;margin-bottom:24px">
    <div class="retro-corners"></div>
    <div class="retro-corners-b"></div>
    <div style="height:2px;background:linear-gradient(to right,<%= @team_info[:color] %>,transparent)"></div>

    <div style="display:flex;flex-direction:column;align-items:center;gap:16px;padding:24px;text-align:center">
      <%= player_photo(@player_name, @player_team, size: 88, css_class: "shadow-lg border-2 flex-shrink-0") %>

      <div>
        <div style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;justify-content:center;margin-bottom:6px">
          <h1 style="font-size:26px;font-weight:bold;color:rgba(255,255,255,0.95);font-family:Verdana,sans-serif;margin:0"><%= @player_name %></h1>
          <% if @is_captain %>
            <span class="retro-status" style="color:var(--retro-gold);border-color:var(--retro-gold-dim);background:rgba(200,155,60,0.1)">★ CAPITÃO</span>
          <% end %>
        </div>
        <div style="display:flex;flex-wrap:wrap;align-items:center;gap:10px;justify-content:center">
          <%= link_to team_path(@team_info[:slug]),
                style: "display:flex;align-items:center;gap:6px;font-size:17px;color:rgba(255,255,255,0.5);font-family:Verdana,sans-serif;text-decoration:none",
                onmouseover: "this.style.color='var(--retro-gold)'",
                onmouseout:  "this.style.color='rgba(255,255,255,0.5)'" do %>
            <%= team_logo(@player_team, size: 20) %>
            <span><%= @player_team %></span>
          <% end %>
          <span style="color:rgba(255,255,255,0.2)">◆</span>
          <span style="font-size:17px;color:rgba(255,255,255,0.4);font-family:Verdana,sans-serif;text-transform:uppercase"><%= role_label(@player_role) %></span>
        </div>
      </div>

      <!-- Key stats -->
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;width:100%;max-width:480px">
        <% key_stats = [
             [@stats[:kda],      kda_color(@stats[:kda]),                                                  "KDA"],
             [@stats[:games],    "text-white",                                                              "Jogos"],
             ["#{@stats[:win_rate]}%", @stats[:win_rate] >= 60 ? "text-kl-win" : (@stats[:win_rate] >= 40 ? "text-white" : "text-kl-loss"), "Win%"],
             [@stats[:avg_cs_min], "text-kl-gold",                                                         "CS/min"]
           ] %>
        <% key_stats.each do |val, color_class, label| %>
          <div style="text-align:center;padding:12px 8px;border:1px solid var(--retro-gold-dim);background:rgba(200,155,60,0.04)">
            <div style="font-size:22px;font-weight:bold;font-family:Verdana,sans-serif" class="<%= color_class %>"><%= val %></div>
            <div style="font-size:15px;color:rgba(255,255,255,0.35);font-family:Verdana,sans-serif;letter-spacing:0.1em;margin-top:3px;text-transform:uppercase"><%= label %></div>
          </div>
        <% end %>
      </div>
    </div>

    <div style="height:18px;background:linear-gradient(to right,var(--retro-blue),var(--retro-bg));border-top:1px solid var(--retro-gold-dim);display:flex;align-items:center;justify-content:center">
      <span class="retro-panel-footer-label">PLAYER PROFILE ◆ KINGS LENDAS CUP</span>
    </div>
  </div>

  <!-- Stats grid -->
  <div class="grid grid-cols-3 sm:grid-cols-6 gap-2 mb-2">
    <% [[@stats[:kills],"KILLS","var(--color-kl-win)"],[@stats[:deaths],"DEATHS","var(--color-kl-loss)"],[@stats[:assists],"ASSISTS","var(--retro-teal)"],[@stats[:avg_kills],"K/JOGO","rgba(255,255,255,0.7)"],[@stats[:avg_deaths],"D/JOGO","rgba(255,255,255,0.7)"],[@stats[:avg_assists],"A/JOGO","rgba(255,255,255,0.7)"]].each do |val, label, color| %>
      <div style="border:1px solid var(--retro-gold-dim);background:var(--retro-card);padding:12px 8px;text-align:center;position:relative">
        <div style="height:2px;background:linear-gradient(to right,<%= color %>,transparent);margin-bottom:6px"></div>
        <div style="font-size:24px;font-weight:bold;font-family:Verdana,sans-serif;color:<%= color %>"><%= val %></div>
        <div style="font-size:17px;color:rgba(255,255,255,0.3);font-family:Verdana,sans-serif;letter-spacing:0.1em;margin-top:3px"><%= label %></div>
      </div>
    <% end %>
  </div>
  <% if @stats[:games] > 0 %>
    <div class="grid grid-cols-3 gap-2 mb-6">
      <% gold_k = (@stats[:avg_gold].to_f / 1000).round(1) %>
      <% dmg_k  = (@stats[:avg_dmg].to_f  / 1000).round(1) %>
      <% [["#{gold_k}k","GOLD/JOGO","var(--retro-gold)"],["#{dmg_k}k","DMG/JOGO","rgba(255,100,80,0.9)"],[@stats[:avg_cs],"CS/JOGO","rgba(255,255,255,0.5)"]].each do |val, label, color| %>
        <div style="border:1px solid var(--retro-gold-dim);background:var(--retro-card);padding:10px 8px;text-align:center">
          <div style="height:2px;background:linear-gradient(to right,<%= color %>,transparent);margin-bottom:6px"></div>
          <div style="font-size:22px;font-weight:bold;font-family:Verdana,sans-serif;color:<%= color %>"><%= val %></div>
          <div style="font-size:15px;color:rgba(255,255,255,0.3);font-family:Verdana,sans-serif;letter-spacing:0.1em;margin-top:3px"><%= label %></div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="mb-6"></div>
  <% end %>

  <!-- Champion stats -->
  <% if @champ_stats.any? %>
    <%= retro_panel(title: "Por Campeão", category: "// STATS", footer: @player_name) do %>
      <div class="overflow-x-auto">
        <table style="width:100%;border-collapse:collapse">
          <thead>
            <tr style="border-bottom:1px solid var(--retro-gold-dim)">
              <th class="retro-table-head" style="text-align:left">Campeão</th>
              <th class="retro-table-head" style="text-align:center">Jogos</th>
              <th class="retro-table-head" style="text-align:center">V/D</th>
              <th class="retro-table-head" style="text-align:center">KDA</th>
              <th class="retro-table-head hidden sm:table-cell" style="text-align:center">K/D/A</th>
              <th class="retro-table-head hidden md:table-cell" style="text-align:center">CS/jogo</th>
            </tr>
          </thead>
          <tbody>
            <% @champ_stats.each do |c| %>
              <tr class="retro-table-row" style="border-bottom:1px solid rgba(200,155,60,0.08)">
                <td style="padding:10px 12px 10px 0">
                  <div style="display:flex;align-items:center;gap:10px">
                    <%= champion_icon(c["champion"], size: 32) %>
                    <span style="font-size:16px;font-weight:bold;color:rgba(255,255,255,0.85);font-family:Verdana,sans-serif"><%= c["champion"] %></span>
                  </div>
                </td>
                <td style="padding:10px 8px;text-align:center;font-size:16px;color:rgba(255,255,255,0.45);font-family:Verdana,sans-serif"><%= c["games"] %></td>
                <td style="padding:10px 8px;text-align:center;font-size:16px;font-family:Verdana,sans-serif">
                  <span style="color:var(--color-kl-win)"><%= c["wins"] %></span><span style="color:rgba(255,255,255,0.2)">/</span><span style="color:var(--color-kl-loss)"><%= c["games"] - c["wins"] %></span>
                </td>
                <td style="padding:10px 8px;text-align:center">
                  <span style="font-size:17px;font-weight:bold;font-family:Verdana,sans-serif" class="<%= kda_color(c['kda']) %>"><%= c["kda"] %></span>
                </td>
                <td class="hidden sm:table-cell" style="padding:10px 8px;text-align:center;font-size:17px;font-family:Verdana,sans-serif">
                  <span style="color:var(--color-kl-win)"><%= c["avg_kills"] %></span><span style="color:rgba(255,255,255,0.2)">/</span><span style="color:var(--color-kl-loss)"><%= c["avg_deaths"] %></span><span style="color:rgba(255,255,255,0.2)">/</span><span style="color:var(--retro-teal)"><%= c["avg_assists"] %></span>
                </td>
                <td class="hidden md:table-cell" style="padding:10px 8px;text-align:center;font-size:17px;color:rgba(255,255,255,0.4);font-family:Verdana,sans-serif"><%= c["avg_cs"] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  <% end %>

  <!-- Match history -->
  <div style="margin-top:24px">
    <div style="margin-bottom:12px">
      <div class="retro-section-label">// HISTÓRICO</div>
      <span class="retro-title">Histórico de Partidas</span>
    </div>
    <div style="display:flex;flex-direction:column;gap:6px">
      <% @match_history.each do |game| %>
        <% sg = @games_index[game["UniqueGame"]] %>
        <% if sg %>
          <% won = sg["Winner"] == game["Team"] %>
          <% opp = sg["Team1"] == game["Team"] ? sg["Team2"] : sg["Team1"] %>
          <% is_sub = game["Team"] != @player_team %>
          <div style="display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid <%= is_sub ? 'rgba(5,150,170,0.4)' : 'rgba(200,155,60,0.12)' %>;background:var(--retro-card)">
            <span class="retro-status" style="font-size:16px;padding:3px 8px;flex-shrink:0;color:<%= won ? 'var(--color-kl-win)' : 'var(--color-kl-loss)' %>;border-color:<%= won ? 'var(--color-kl-win)' : 'var(--color-kl-loss)' %>"><%= won ? 'V' : 'D' %></span>
            <%= champion_icon(game["Champion"], size: 28) %>
            <div style="flex:1;min-width:0">
              <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
                <span style="font-size:17px;font-weight:bold;color:rgba(255,255,255,0.85);font-family:Verdana,sans-serif"><%= game["Champion"] %></span>
                <span style="font-size:16px;color:rgba(255,255,255,0.3);font-family:Verdana,sans-serif">vs</span>
                <%= team_logo(opp, size: 16) %>
                <span style="font-size:17px;color:rgba(255,255,255,0.5);font-family:Verdana,sans-serif;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= opp %></span>
                <% if is_sub %>
                  <span style="display:inline-flex;align-items:center;gap:4px;font-size:14px;letter-spacing:0.08em;padding:2px 6px;border:1px solid var(--color-kl-teal);color:var(--color-kl-teal);font-family:Verdana,sans-serif;flex-shrink:0">
                    SUB <%= team_abbr(game["Team"]) %>
                  </span>
                <% end %>
              </div>
              <div style="font-size:16px;color:rgba(255,255,255,0.3);font-family:Verdana,sans-serif;margin-top:2px">
                <%= format_datetime_brt(sg["DateTime_UTC"]) %>
                <% if is_sub %>
                  · jogou pelo <%= game["Team"] %>
                <% end %>
              </div>
            </div>
            <div style="text-align:right;flex-shrink:0">
              <div style="font-size:16px;font-weight:bold;font-family:Verdana,sans-serif">
                <span style="color:var(--color-kl-win)"><%= game["Kills"] %></span><span style="color:rgba(255,255,255,0.2)">/</span><span style="color:var(--color-kl-loss)"><%= game["Deaths"] %></span><span style="color:rgba(255,255,255,0.2)">/</span><span style="color:var(--retro-teal)"><%= game["Assists"] %></span>
              </div>
              <div style="font-size:16px;color:rgba(255,255,255,0.3);font-family:Verdana,sans-serif"><%= format_game_duration(sg["Gamelength"]) %></div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
