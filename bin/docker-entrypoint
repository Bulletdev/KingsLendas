#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# Remove stale PID if present
rm -f tmp/pids/server.pid

# Prepare only local SQLite databases on boot.
# The leaguepedia (Supabase/PostgreSQL) database is managed externally — skip it here
# to avoid crash when Supabase is paused or unreachable.
./bin/rails db:prepare:primary db:prepare:queue

# Populate data on first boot (idempotent — skips if already populated)
./bin/rails leaguepedia:bootstrap 2>/dev/null || true

exec "${@}"
